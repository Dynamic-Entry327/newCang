<!DOCTYPE html>
<html lang="pt-ao">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
       <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="icon" href='https://imglur.com/get/r7vlDV.png'>
    
    <link rel="stylesheet" href="fonts/fontawesome-free-7.2.0-web/css/all.css">
    <link rel="stylesheet" href="fonts/fontawesome-free-7.2.0-web/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="css/header.css">
    <link rel="stylesheet" href="css/searchPage.css">
    <title>Projectent Animes - Pesquisar</title>
    <style>
        *{
    border: 0;
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body{
    font-family: Arial,"Time New Roman",sans-serif;
    background-color: rgb(22, 22, 22);
    color: #e8e9e7;
}

.main{
    width: 95%;
    margin: 40px auto;
    height: 40vh;
}
.main .content{
    width: 100%;
}
.main .content h2{
    position: relative;
    background-color: #0b6100;
    line-height: 8vh;
    padding-left: 16px;
    font-size: 3.5vw;
    margin-bottom: 30px;
}
.main .content h2::before{
    content: "";
    background-color: #f1f1f1;
    height: 6.5vh;
    padding: 6px;
    position: absolute;
    left: 0;
}
.main .content form{
    width: 90%;
    margin: auto;
    padding: 10px;
}
.main .content form input[type=search]{
    padding: 10px 4px;
    width: 45%;
}
.main .content form input[type=submit]{
    padding: 10px 4px;
    width: 24%;
    background-color: #2b7dca;
    color: #fff;
    cursor: pointer;
}

.main .content form input[type=submit]:hover{
    background-color: #4ae2e7;
    color: #000000;
}


.main .content .box-cards{
    width: 99%;
    margin: auto;
    border: 1px solid #010a00;
    border-radius: 10px;
    display: grid;
    grid-template-columns: auto auto auto auto auto;
    place-content: center;
    gap: 60px;
    padding: 12px;

}

.main .content .box-cards .cards{
    border: 1px solid #f1f1f1;
    height: 280px;
    box-shadow: 0px 0px 6px #4ae2e7;
    margin-bottom: 80px;

}

.main .content .box-cards .cards a{
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: #f1f1f1;

}

.main .content .box-cards .cards a img{
    width: 100%;
    height: 100%;
    transition: filter 1s ease;
}

.main .content .box-cards .cards a:hover img{
   filter: blur(8px);
}

.main .content .box-cards .cards a .legend{
    position: absolute;
    padding: 5px;
    
}

.titulo {
  width: 100%;
  bottom: -80px;
  text-align: center;
  font-size: 1.3vw;
  
}



hr{
    border: 1px solid #fff;
    width: 95%;
    margin: auto;
}

.footer{
    text-align: center;
}

.footer h1{
    line-height: 80px;
    font-size: 5vw;
}

.footer p{
    line-height: 40px;
    font-size: 3.5vw;

}

@media (max-width:989px) {
    .main .content .box-cards{
    gap: 10px;
    padding: 10px;

}

.main .content .box-cards .cards{
    height: 250px;
    min-width: 90px;

}
    
}

@media (max-width:765px){
    .main .content .box-cards{
    gap: 5px;
    padding: 5px;

}
    .main .content .box-cards .cards{
    height: 200px;
  
}
}

@media (max-width:524px){
    #mobile{display: flex;}
    #desktop-bar{display: none;}
    .main .content .box-cards{
    gap: 5px;
    padding: 0;
    border: none;

}
    .main .content .box-cards .cards{
    height: 150px;
  
}
}

@media (max-width:488px){
    #desktop-bar{display: none;}
    .main .content .box-cards{
    gap: 1px;
    padding: 0;
    border: none;

}
    .main .content .box-cards .cards{
    height: 150px;
  
}
}

@media (max-width:472px){
    #desktop-bar{display: none;}
    .main .content .box-cards{
    grid-template-columns: auto auto auto auto;
    gap: 4px;
    padding: 0;
    border: none;

}
    .main .content .box-cards .cards{
    height: 150px;
  
}
}

@media (max-width:472px){
    #desktop-bar{display: none;}
    .main .content .box-cards{
    grid-template-columns: auto auto auto;
    gap: 4px;
    padding: 0;
    border: none;

}
    .main .content .box-cards .cards{
    height: 150px;
  
}
}

@media (max-width:297px){
    #desktop-bar{display: none;}
    .main .content .box-cards{
    grid-template-columns: auto auto;
    gap: 4px;
    padding: 0;
    border: none;

}
    .main .content .box-cards .cards{
    height: 150px;
  
}
}
    </style>
        <script src="https://pl29332336.profitablecpmratenetwork.com/32/ac/87/32ac87b22a31578e408a336d707868c2.js"></script>
</head>
<body>
 <div class="header">
        <div class="logo">
            <a href="/">
                <img src='https://imglur.com/get/XN4hTb.png' alt='XN4hTb'>
            </a>
        </div>
        <div class="navbar">
            <ul id="mobile">
                <li id="ico-menu"><i class="fa-solid fa-bars"></i></li>
            </ul>
            <ul id="desktop-bar">
                <li><a href="/">Pagina inicial</a></li>
                <li><a href="/lancamentos">Lançamentos</a></li>
                <li><a href="/search">Pesquisar</a></li>
                <li><a href="/sobre">Sobre</a></li>
            </ul>
        </div>
        <div class="menubar">
            <i class="fa-solid fa-close"></i>
             <ul>
                <li><form action="/search"><input type="search"><input type="submit" value="Pesquisar"></form></li>
                <li><a href="/">Pagina inicial</a></li>
                <li><a href="/lancamentos">Lançamentos</a></li>
                <li><a href="/sobre">Sobre</a></li>
            </ul>
        </div>
    </div>


    <div class="main">
        <div class="content">
            <h2>Pesquisa</h2>
            <form action="/search" method="get">
                <input type="search" name="title">
                <input type="submit" value="Pesquisar">
            </form>
            <% if(dados){%>
            <div class="box-cards">
            <% dados.forEach(item => { %>
         <div class="cards">
                    <a href="/info?url=<%=item.url%>?odr=1">
                        <img src="<%= item.src %>" alt="">
                        <div class="legend titulo">
                            <h3><%= item.title %></h3>
                        </div>
                        <div class="legend episodio">
                            <h4><%= item.episode %></h4>
                        </div>
                    </a>
                </div>
<% }) %>
        
    </div>
    <% }%>
            </div>
        </div>
    </div>

    <hr>
    
    <div class="footer">
        <h1>Projectent</h1>
                <p>Este site não utiliza o proprio servidor para hospedar os videos.</p>
        <p>Siga as nossas páginas do Facebook para mais informações.</p>
    </div>

        <script>
    const menu = document.querySelector('#ico-menu')
    const menuBar = document.querySelector('.menubar')
    const close = document.querySelector('.fa-close')



menu.addEventListener('click',()=>{
    menuBar.classList.toggle('showmenu')

})

close.addEventListener('click',()=>{
    menuBar.classList.toggle('showmenu')

})
    </script>

</body>
</html>
